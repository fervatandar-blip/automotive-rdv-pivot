NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only — never prefix with NEXT_PUBLIC_. Used for admin-level test
# data setup/cleanup (creating/deleting users via the Supabase Admin API).
# Never referenced from client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: appointment status-change emails go through Resend when set.
# Without it, emails are logged to the server console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=RDV <onboarding@resend.dev>

# Optional: the garage location picker (onboarding) and map display (garage
# detail page) both no-op gracefully when this is unset. Needs Maps
# JavaScript API enabled and billing on in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Required for bookings: clients pay via Stripe Checkout at booking time,
# garages are Stripe Connect Express accounts, the platform takes a cut via
# an application fee. Server-only -- never prefix with NEXT_PUBLIC_ (there is
# no client-side Stripe.js in this app; Checkout is fully hosted by Stripe).
STRIPE_SECRET_KEY=your-stripe-secret-key
# From the webhook endpoint's settings in the Stripe dashboard, once
# registered against https://<your-domain>/api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret
# Flat percentage of each booking's service price the platform keeps.
PLATFORM_COMMISSION_PERCENT=15

# Optional: web push (Firebase Cloud Messaging). Without these, the "Enable
# push notifications" button on the dashboard stays hidden and push sends
# are logged to the server console instead of delivered. Public values come
# from the Firebase console's web app config; the VAPID key comes from
# Project settings -> Cloud Messaging -> Web Push certificates.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# Server-only, from a service account JSON (Project settings -> Service
# accounts -> Generate new private key). Never prefix with NEXT_PUBLIC_.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Required for the daily retention-cleanup cron (vercel.json) to run:
# generate any random string, and set the same value in the Vercel
# project's environment variables. Vercel Cron sends it automatically as
# "Authorization: Bearer $CRON_SECRET" -- without a match, the route 403s.
CRON_SECRET=

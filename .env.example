NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only — never prefix with NEXT_PUBLIC_. Used for admin-level test
# data setup/cleanup (creating/deleting users via the Supabase Admin API).
# Never referenced from client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: appointment status-change emails go through Resend when set.
# Without it, emails are logged to the server console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=RDV <onboarding@resend.dev>

# Optional: the garage location picker (onboarding) and map display (garage
# detail page) both no-op gracefully when this is unset. Needs Maps
# JavaScript API enabled and billing on in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
